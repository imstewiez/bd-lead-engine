{
  "name": "aveniq-lead-workspace",
  "version": "0.3.4",
  "private": true,
  "description": "AVENIQ — automated lead intelligence workspace for modern revenue teams.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "check": "node --check src/server.js && node --check public/app.js && node --check src/commercial-intelligence.js && node --check src/noise-policy.js && node --check src/quality-repair.js && node --check src/restore-specialist-leads.js && node --check src/cleanup-leads.js && node --check src/activity-report.js",
    "activity": "node src/activity-report.js",
    "activity:overnight": "node src/activity-report.js --hours=12",
    "quality:repair": "node src/quality-repair.js",
    "quality:restore-specialists": "node src/restore-specialist-leads.js",
    "quality:cleanup": "node src/cleanup-leads.js",
    "scan": "node src/scan-cli.js",
    "deep": "node src/deep-enrich-cli.js",
    "autopilot": "node src/autopilot.js",
    "harvest": "node src/source-harvester.js",
    "enrich": "node src/enrichment-worker.js",
    "qualified-exporter": "node src/qualified-exporter.js",
    "supervisor": "node src/supervisor.js",
    "recover": "node src/recover-leads.js",
    "background": "node src/launch-background.js",
    "background:status": "node src/background-control.js status",
    "background:stop": "node src/background-control.js stop",
    "background:kill": "node src/background-control.js kill",
    "audit": "node src/sourcing-audit.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "express": "^4.21.2"
  }
}
